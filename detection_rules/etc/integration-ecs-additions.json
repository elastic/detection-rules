{
  "_description": [
    "ECS fields an integration populates that are not declared in its package field definitions,",
    "typically injected by ingest pipelines (e.g. enrichment processors) or by the Elastic Agent",
    "itself (e.g. add_host_metadata). Keys are package names; nested keys are data stream names,",
    "or '_all' to apply to every data stream in the package. The top-level '_all_packages' list",
    "holds fields the Elastic Agent / Fleet final pipeline stamps on every shipped event.",
    "These fields are added to the integration schema during query validation for packages",
    "that otherwise declare their ECS fields explicitly (strict ECS scoping). Each entry should",
    "be justified by the integration's ingest pipeline, agent processor defaults, or documented",
    "exported fields."
  ],
  "_all_packages": [
    "agent.build.original",
    "agent.ephemeral_id",
    "agent.id",
    "agent.name",
    "agent.type",
    "agent.version",
    "ecs.version",
    "event.agent_id_status",
    "event.ingested"
  ],
